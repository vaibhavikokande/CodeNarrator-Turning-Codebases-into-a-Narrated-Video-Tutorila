# ═══════════════════════════════════════════════════════
#  CodeNarrator — Backend Environment Configuration
# ═══════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────
# Options: gemini (default) | claude | openrouter
LLM_PROVIDER=gemini

# Google Gemini (PRIMARY — recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (optional fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (secondary fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── TTS Provider ──────────────────────────────────────
# Options: elevenlabs (default) | edge_tts
TTS_PROVIDER=elevenlabs

# ElevenLabs (high-quality AI voices)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── GitHub ────────────────────────────────────────────
# Optional: increases API rate limits from 60 to 5000 req/hr
GITHUB_TOKEN=your_github_token_here

# ── Storage ───────────────────────────────────────────
OUTPUT_DIR=./output

# ── Defaults ─────────────────────────────────────────
DEFAULT_LANGUAGE=English
DEFAULT_THEME=dark
DEFAULT_VOICE=en-US-AriaNeural

# ── Performance ───────────────────────────────────────
FAST_MAX_FILES=220
FAST_TUTORIAL_MAX_FILES=4
